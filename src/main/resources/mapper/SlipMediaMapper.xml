<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.SlipMediaMapper">

    <insert id="insert" parameterType="com.example.demo.entity.SlipMedia" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO slip_media (
            slip_id,
            media_name,
            release_date,
            note
        ) VALUES (
            #{slipId},
            #{mediaName},
            #{releaseDate},
            #{note}
        )
    </insert>

    <delete id="deleteBySlipId">
        DELETE FROM slip_media
        WHERE slip_id = #{slipId}
    </delete>

</mapper>
