<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.MasterSettingMapper">

    <select id="find" resultType="com.example.demo.entity.MasterSetting">
        SELECT id,
               master_text AS masterText,
               updated_at AS updatedAt
        FROM master_setting
        ORDER BY id
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.example.demo.entity.MasterSetting" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO master_setting (
            master_text
        ) VALUES (
            #{masterText}
        )
    </insert>

    <update id="update" parameterType="com.example.demo.entity.MasterSetting">
        UPDATE master_setting
        SET master_text = #{masterText},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

</mapper>
